<?php
/** @var WilchersFormBuilderBlockFrontendFormRenderer $block */
$form = $block->getForm();
$identifier = $block->getIdentifier();
?>
<?php if (!$form): ?>
<div class="message error"><span><?= __('Dit formulier is niet beschikbaar.') ?></span></div>
<?php return; endif; ?>

<div class="wilchers-form-page">

<?php if ($identifier === 'herroeping'): ?>
<div class="herroeping-intro">
  <h1>Herroeping &amp; Retour</h1>
  <div class="herroeping-uitleg">
    <p>Op grond van de Europese consumentenrechtenrichtlijn (EU 2011/83) heeft u het recht om binnen
    <strong>14 dagen</strong> na ontvangst, zonder opgave van reden, uw aankoop te herroepen.
    Na herroeping heeft u nog 14 dagen om het product retour te sturen.</p>
    <h3>Retourvoorwaarden</h3>
    <ul>
      <li>Het product moet ongebruikt en onbeschadigd zijn.</li>
      <li>U draagt zelf de retourkosten.</li>
      <li>Na ontvangst vergoeden wij het volledige aankoopbedrag inclusief de oorspronkelijke verzendkosten.</li>
    </ul>
    <p class="model-note"><em>Dit digitale formulier heeft dezelfde juridische werking als het wettelijke
    modelformulier voor herroeping (EU Richtlijn 2011/83/EU, Bijlage I-B).</em></p>
  </div>
</div>
<?php else: ?>
<h1 class="page-title"><?= $block->escapeHtml($form->getTitle()) ?></h1>
<?php endif; ?>

<?php $messages = $block->getLayout()->getMessagesBlock(); $messages->addStorageType(MagentoFrameworkMessageMessageInterface::TYPE_SUCCESS); $messages->addStorageType(MagentoFrameworkMessageMessageInterface::TYPE_ERROR); $messages->addMessages($block->getLayout()->getMessageStorage()->getMessages()); ?>
<?= $messages->toHtml() ?>

<form class="wilchers-form" action="<?= $block->escapeUrl($block->getFormAction()) ?>" method="post">
  <?= $block->getBlockHtml('formkey') ?>
  <input type="hidden" name="identifier" value="<?= $block->escapeHtmlAttr($identifier) ?>"/>

  <?php foreach ($form->getFieldsConfig() as $f):
    $n    = $block->escapeHtmlAttr($f['name']);
    $lbl  = $block->escapeHtml($f['label']);
    $type = $f['type'] ?? 'text';
    $req  = !empty($f['required']);
  ?>
  <div class="field<?= $req ? ' required' : '' ?>">
    <?php if ($type !== 'checkbox'): ?>
    <label for="wf_<?= $n ?>"><?= $lbl ?><?= $req ? ' <span class="req">*</span>' : '' ?></label>
    <?php endif; ?>
    <div class="control">
    <?php if ($type === 'textarea'): ?>
      <textarea id="wf_<?= $n ?>" name="<?= $n ?>" rows="5"<?= $req?' required':'' ?>></textarea>
    <?php elseif ($type === 'checkbox'): ?>
      <label class="checkbox-label"><input type="checkbox" id="wf_<?= $n ?>" name="<?= $n ?>" value="1"/> <?= $lbl ?></label>
    <?php elseif ($type === 'select'): ?>
      <select id="wf_<?= $n ?>" name="<?= $n ?>"<?= $req?' required':'' ?>><option value="">— kies —</option></select>
    <?php else: ?>
      <input type="<?= $block->escapeHtmlAttr($type) ?>" id="wf_<?= $n ?>" name="<?= $n ?>"<?= $req?' required':'' ?>/>
    <?php endif; ?>
    </div>
  </div>
  <?php endforeach; ?>

  <div class="form-actions">
    <button type="submit" class="action primary wilchers-submit">
      <span><?= $identifier === 'herroeping' ? 'Herroeping bevestigen' : 'Versturen' ?></span>
    </button>
  </div>
</form>

<?php if ($identifier === 'herroeping'): ?>
<p class="legal-footer"><small>Door op "Herroeping bevestigen" te klikken oefent u uw wettelijk herroepingsrecht
uit conform EU-Richtlijn 2011/83/EU. U ontvangt een e-mailbevestiging met datum en tijdstip van ontvangst.</small></p>
<?php endif; ?>
</div>

